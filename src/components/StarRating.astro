---
interface Props {
  rating: number;
  showNumber?: boolean;
}
const { rating, showNumber = true } = Astro.props;
const full = Math.floor(rating);
const hasHalf = rating - full >= 0.5;
const empty = 5 - full - (hasHalf ? 1 : 0);
---
<span class="star-rating" role="img" aria-label={`Rated ${rating} out of 5 stars`}>
  {Array.from({ length: full }).map(() => <span class="star full">&#9733;</span>)}
  {hasHalf && <span class="star half">&#9733;</span>}
  {Array.from({ length: empty }).map(() => <span class="star empty">&#9733;</span>)}
  {showNumber && <span class="rating-number">{rating.toFixed(1)}</span>}
</span>

<style>
  .star-rating {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    font-size: 1rem;
  }
  .star.full {
    color: var(--gold);
  }
  .star.half {
    color: var(--gold);
    opacity: 0.55;
  }
  .star.empty {
    color: var(--border);
  }
  .rating-number {
    margin-left: 0.4rem;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--fg-muted);
    font-family: var(--sans);
  }
</style>
