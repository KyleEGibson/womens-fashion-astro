---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ReadingProgressBar from "../components/ReadingProgressBar.astro";
import { siteConfig } from "../site.config";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  showReadingProgress?: boolean;
  schema?: Record<string, any>;
}

const {
  title,
  description,
  image = "/images/hero.jpg",
  showReadingProgress = false,
  schema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteConfig.brandName,
  url: Astro.site?.toString(),
  description: siteConfig.description,
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title} | {siteConfig.brandName}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteConfig.brandName} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={siteConfig.googleFontsUrl} rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  </head>
  <body>
    {showReadingProgress && <ReadingProgressBar />}
    <Header />
    <slot />
    <Footer />
  </body>
</html>
