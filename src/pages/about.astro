---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { siteConfig } from "../site.config";
---
<BaseLayout title="About" description={`About ${siteConfig.brandName} — independent, evidence-based product reviews.`}>
  <main class="container static-page">
    <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "About" }]} />
    <h1>About {siteConfig.brandName}</h1>
    <p>{siteConfig.brandName} was started with one goal: cut through the noise of near-identical product listings to highlight the ones actually worth buying.</p>
    <p>We don't accept payment for placement. Every product featured on this site earned its spot through hands-on performance testing, research, and verified customer feedback — not sponsorships.</p>
    <p>Our reviews are checked against real research and testing rather than marketing copy.</p>
  </main>
</BaseLayout>

<style>
  .static-page { max-width: 680px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
  .static-page h1 { font-size: 2.2rem; margin: 0.5rem 0 1.25rem; }
  .static-page p { color: var(--fg-muted); margin-bottom: 1.1rem; }
</style>
