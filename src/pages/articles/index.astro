---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ProductCard from "../../components/ProductCard.astro";

const articles = (await getCollection("articles")).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
const dateFmt = (d: Date) => d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
---
<BaseLayout title="Articles & Guides" description="Practical, evidence-based articles and guides.">
  <main class="container articles-index">
    <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Articles" }]} />
    <header class="page-header">
      <p class="eyebrow">Latest</p>
      <h1>Articles</h1>
      <p class="page-sub">Practical, evidence-based guides and updates.</p>
    </header>
    <div class="card-grid">
      {articles.map((a) => (
        <ProductCard href={`/articles/${a.slug}/`} image={a.data.image} imageAlt={a.data.imageAlt} category={a.data.category} title={a.data.title} author={a.data.author} date={dateFmt(a.data.publishDate)} readingTime="5 min read" excerpt={a.data.excerpt} />
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .articles-index { padding: 2rem 1.5rem 3rem; }
  .page-header { max-width: 640px; margin-bottom: 2rem; }
  .page-header h1 { font-size: 2.2rem; margin: 0.4rem 0 0.6rem; }
  .page-sub { color: var(--fg-muted); }
</style>
