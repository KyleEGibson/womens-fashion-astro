---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";
import ProductCard from "../../components/ProductCard.astro";

export async function getStaticPaths() {
  const guides = await getCollection("guides");
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide, allGuides: guides },
  }));
}

const { guide, allGuides } = Astro.props;
const { Content } = await guide.render();
const d = guide.data;

const related = allGuides.filter((g) => g.slug !== guide.slug && g.data.category === d.category).slice(0, 3);
const dateFmt = d.publishDate.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: d.comparisonTable.map((row: any, i: number) => ({
    "@type": "ListItem",
    position: i + 1,
    name: row.name,
  })),
};
---
<BaseLayout title={d.title} description={d.excerpt} image={d.image} showReadingProgress={true} schema={itemListSchema}>
  <main class="container guide-page">
    <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Buying Guides", href: "/guides/" }, { label: d.title }]} />

    <article class="guide-body">
      <span class="card-category">{d.category}</span>
      <h1>{d.title}</h1>
      <div class="review-meta">
        <span>By {d.author}</span>
        <span>&middot; {dateFmt}</span>
      </div>
      <img class="hero-image" src={d.image} alt={d.imageAlt} width="900" height="500" loading="lazy" />
      <p class="intro">{d.intro}</p>

      <h2>Comparison Table</h2>
      <ComparisonTable rows={d.comparisonTable} />

      <div class="prose">
        <Content />
      </div>
    </article>

    {related.length > 0 && (
      <section class="section related">
        <div class="section-heading"><h2>Related Guides</h2></div>
        <div class="card-grid">
          {related.map((g) => (
            <ProductCard href={`/guides/${g.slug}/`} image={g.data.image} imageAlt={g.data.imageAlt} category={g.data.category} title={g.data.title} excerpt={g.data.excerpt} linkLabel="Read Guide" />
          ))}
        </div>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .guide-page { padding: 2rem 1.5rem 3rem; }
  .guide-body { max-width: 820px; margin: 0 auto; }
  .guide-body h1 { font-size: 2.2rem; margin: 0.5rem 0 0.6rem; }
  .card-category {
    display: inline-block; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.05em;
    text-transform: uppercase; color: var(--accent-dark); background: var(--accent-soft);
    padding: 0.3rem 0.7rem; border-radius: 999px; margin-bottom: 0.5rem;
  }
  .review-meta { color: var(--fg-muted); font-size: 0.85rem; margin-bottom: 1rem; }
  .hero-image { width: 100%; border-radius: var(--radius-lg); margin: 0.5rem 0 1.5rem; object-fit: cover; }
  .intro { font-size: 1.05rem; color: var(--fg-muted); margin-bottom: 1.5rem; }
  .guide-body h2 { font-size: 1.5rem; margin: 2rem 0 0.75rem; }
  .prose :global(h2) { font-size: 1.4rem; margin: 1.75rem 0 0.75rem; }
  .prose :global(p) { margin: 0 0 1.1rem; }
  .related { margin-top: 3rem; border-top: 1px solid var(--border); padding-top: 2.5rem; max-width: 1080px; margin-left: auto; margin-right: auto; }
</style>
