---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { siteConfig } from "../site.config";
---
<BaseLayout title="Terms of Service" description={`${siteConfig.brandName} terms of service.`}>
  <main class="container static-page">
    <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Terms of Service" }]} />
    <h1>Terms of Service</h1>
    <p>Last updated {new Date().toLocaleDateString("en-US", { month: "long", year: "numeric" })}.</p>
    <p>By using {siteConfig.brandName}, you agree that content on this site is for informational purposes only and is not a substitute for professional advice. Always verify product details before purchase.</p>
    <p>Product reviews reflect our genuine testing experience and research at the time of publication; individual results may vary. We update reviews periodically but cannot guarantee real-time accuracy of third-party pricing or availability.</p>
  </main>
</BaseLayout>

<style>
  .static-page { max-width: 680px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
  .static-page h1 { font-size: 2.2rem; margin: 0.5rem 0 1.25rem; }
  .static-page p { color: var(--fg-muted); margin-bottom: 1.1rem; }
</style>
